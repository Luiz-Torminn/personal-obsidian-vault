
# -----------------------------------------------------------------------------
# Obsidian Vault .gitignore
# Purpose:
# - Keep personal notes and vault content versioned
# - Exclude device-specific Obsidian settings
# - Exclude macOS metadata
# - Exclude cache, temporary, sync, and plugin build artifacts
# -----------------------------------------------------------------------------

# =============================================================================
# macOS system files
# =============================================================================

.DS_Store
.AppleDouble
.LSOverride

# Icon files generated by macOS
Icon?

# Thumbnails and Finder metadata
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns

# Network share metadata
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk


# =============================================================================
# Obsidian core workspace / device-specific UI state
# =============================================================================

# Workspace layout, open tabs, panes, recent files, graph position, etc.
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Newer Obsidian workspace files may be numbered or duplicated
.obsidian/workspace*.json

# Device-specific appearance and app state
.obsidian/appearance.json
.obsidian/app.json
.obsidian/hotkeys.json

# Device-specific core plugin state
.obsidian/core-plugins.json
.obsidian/core-plugins-migration.json

# Device-specific graph settings
.obsidian/graph.json
.obsidian/local-graph.json

# Device-specific canvas state, when applicable
.obsidian/canvas.json

# Device-specific backlink/search/starred state
.obsidian/backlinks.json
.obsidian/bookmarks.json
.obsidian/starred.json
.obsidian/search.json

# Device-specific daily note state, slash command state, etc.
.obsidian/daily-notes.json
.obsidian/command-palette.json
.obsidian/page-preview.json
.obsidian/switcher.json

# Obsidian cache and internal app data
.obsidian/cache/
.obsidian/tmp/
.obsidian/.cache/

# Community plugin folders can include bundled secrets, local tokens, and generated state.
**/.obsidian/plugins/


# =============================================================================
# Obsidian community plugin device-specific data
# =============================================================================

# Many plugins store machine-specific, window-specific, token-specific,
# cache, or generated state inside their plugin folders.
#
# Keep installed plugin source/config files only if you intentionally want
# to version them. Otherwise, ignore plugin data broadly and whitelist manually.

# Plugin caches
.obsidian/plugins/**/cache/
.obsidian/plugins/**/.cache/
.obsidian/plugins/**/tmp/
.obsidian/plugins/**/temp/
.obsidian/plugins/**/logs/
.obsidian/plugins/**/log/

# Plugin generated files
.obsidian/plugins/**/*.log
.obsidian/plugins/**/*.tmp
.obsidian/plugins/**/*.temp
.obsidian/plugins/**/*.cache
.obsidian/plugins/**/*.bak
.obsidian/plugins/**/*.old

# Plugin package/build artifacts
.obsidian/plugins/**/node_modules/
.obsidian/plugins/**/dist/
.obsidian/plugins/**/build/
.obsidian/plugins/**/.turbo/
.obsidian/plugins/**/.vite/
.obsidian/plugins/**/.parcel-cache/

# Plugin development files
.obsidian/plugins/**/.env
.obsidian/plugins/**/.env.local
.obsidian/plugins/**/.env.*.local

# Plugin lock files, usually unnecessary inside a vault unless developing plugins
.obsidian/plugins/**/package-lock.json
.obsidian/plugins/**/yarn.lock
.obsidian/plugins/**/pnpm-lock.yaml
.obsidian/plugins/**/bun.lockb


# =============================================================================
# Obsidian Sync / conflict files
# =============================================================================

# Obsidian Sync conflict files
*.sync-conflict-*
*.conflict-*

# iCloud conflict files
* (conflicted copy)*

# Dropbox conflict files
* conflicted copy *
* conflicted copy.*

# OneDrive conflict files
* - Copy.*
* - copy.*

# Syncthing conflict files
*.sync-conflict-*
*.stfolder/
.stversions/

# Generic duplicate/conflict patterns
*_conflict*
*_Conflict*
* conflicted *
* conflict *


# =============================================================================
# Temporary editor files
# =============================================================================

# Vim
*.swp
*.swo
*.swn
*.un~
.Session.vim

# Emacs
*~
\#*\#
.\#*

# VS Code / Cursor / editors
.vscode/
.cursor/
.idea/

# Sublime Text
*.sublime-workspace

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*.rej

# =============================================================================
# Logs
# =============================================================================

*.log
logs/
log/


# =============================================================================
# Environment / secrets
# =============================================================================

.env
.env.local
.env.*.local

*.pem
*.key
*.crt
*.p12
*.pfx

secrets/
private/
credentials/


# =============================================================================
# Node / JavaScript tooling
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

.npm/
.yarn/
.pnpm-store/

dist/
build/
.cache/
.parcel-cache/
.turbo/
.vite/


# =============================================================================
# Python tooling, if scripts are kept inside the vault
# =============================================================================

__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/


# =============================================================================
# Attachments / exported files that may bloat the repository
# Uncomment these if you do not want large binary files versioned.
# =============================================================================

# PDFs
# *.pdf

# Images
# *.png
# *.jpg
# *.jpeg
# *.gif
# *.webp
# *.heic
# *.tiff
# *.bmp
# *.svg

# Audio
*.mp3
*.wav
*.m4a
*.aac
*.flac
*.ogg

# Video
*.mp4
*.mov
*.avi
*.mkv
*.webm

# Office documents
# *.doc
# *.docx
# *.xls
# *.xlsx
# *.ppt
# *.pptx

# Archives
# *.zip
# *.tar
# *.tar.gz
# *.rar
# *.7z

# Smart Composer local databases and generated vector archives
**/.smtcmp_json_db/
**/.smtcmp_vector_db.tar.gz


# =============================================================================
# Optional: large local-only folders
# Adjust these based on your vault structure.
# =============================================================================

# Local exports
exports/
export/
generated/
generated-files/

# Local inbox/import folders
.local/
.local-only/
tmp/
temp/

# Large attachment folders
# attachments/
# assets/
# media/
# files/


# =============================================================================
# Optional: keep useful Obsidian configuration versioned
# =============================================================================
#
# By default, this .gitignore avoids the most common device-specific files.
# You may still choose to commit stable configuration files such as:
#
# .obsidian/templates.json
# .obsidian/types.json
# .obsidian/community-plugins.json
# .obsidian/plugins/<plugin-name>/manifest.json
# .obsidian/plugins/<plugin-name>/main.js
# .obsidian/plugins/<plugin-name>/styles.css
#
# Avoid committing files that contain:
# - Access tokens
# - API keys
# - Absolute local paths
# - Device-specific settings
# - Cache or generated data
